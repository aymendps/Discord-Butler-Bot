{
  "name": "discord-butler-bot",
  "version": "1.0.0.0",
  "bin": "./dist/main.js",
  "pkg": {
    "targets": [
      "node24-win-x64"
    ],
    "outputPath": "build",
    "assets": [
      ".env.package",
      ".data/**/*"
    ]
  },
  "scripts": {
    "start": "ts-node src/main.ts",
    "dev": "nodemon src/main.ts",
    "build": "tsc --build --force",
    "package": "pkg . --sea && node -e \"require('fs').copyFileSync('LICENSE','build/LICENSE'); require('fs').cpSync('.data/dj','build/build_deps/dj',{recursive:true})\"",
    "sign": "npx resedit build/discord-butler-bot.exe build/discord-butler-bot.exe --ignore-signed --definition resedit.definition.json --file-version %npm_package_version% --product-version %npm_package_version%",
    "release": "npm run build && npm run package && npm run sign"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@distube/ytdl-core": "^4.16.12",
    "@snazzah/davey": "^0.1.11",
    "axios": "^1.18.1",
    "discord.js": "^14.25.1",
    "dotenv": "^16.0.3",
    "ffmpeg": "^0.0.4",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "he": "^1.2.0",
    "isomorphic-unfetch": "^4.0.2",
    "mongoose": "^9.7.4",
    "play-dl": "github:aymendps/play-dl",
    "spotify-url-info": "^3.3.0",
    "tweetnacl": "^1.0.3",
    "youtube-dl-exec": "^3.1.9",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/he": "^1.2.3",
    "@types/node": "^25.6.0",
    "@yao-pkg/pkg": "^6.21.0",
    "nodemon": "^3.1.14",
    "resedit-cli": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
